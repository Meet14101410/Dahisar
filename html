<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dahisar - The Gateway of Mumbai</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background: #f8fafc; display: flex; justify-content: center; padding: 20px; }
        .suburb-card { background: white; width: 480px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); border-top: 6px solid #fbbf24; overflow: hidden; }
        .header { background: #fffbeb; padding: 20px; text-align: center; border-bottom: 1px solid #fef3c7; }
        .content { padding: 25px; line-height: 1.6; color: #334155; }
        .label { font-weight: bold; color: #b45309; }
        .metro-badge { background: #dcfce7; color: #166534; padding: 2px 8px; border-radius: 4px; font-size: 0.85em; font-weight: bold; }
    </style>
</head>
<body>
    <div class="suburb-card">
        <div class="header"><h1>📍 Dahisar</h1><p>Mumbai Suburban District</p></div>
        <div class="content">
            <p><span class="label">Location:</span> North Mumbai Gateway</p>
            <p><span class="label">Railway Code:</span> DIC (Western Line)</p>
            <p><span class="label">Metro Hub:</span> <span class="metro-badge">Line 2A & 7 Interchange</span></p>
            <p><span class="label">Landmarks:</span> SGNP Entrance, Dahisar Check Naka</p>
            <p><span class="label">Pincode:</span> 400068</p>
        </div>
    </div>
</body>
</html>
